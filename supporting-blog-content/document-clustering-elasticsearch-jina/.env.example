# Elasticsearch (use ELASTIC_CLOUD_ID or ELASTIC_HOST, not both)
ELASTIC_CLOUD_ID=<your-cloud-id>
ELASTIC_HOST=<https://your-host:443>
ELASTIC_API_KEY=<your-api-key>
ELASTIC_INDEX_CLUSTERING=docs-clustering
ELASTIC_INDEX_RETRIEVAL=docs-retrieval

# Jina Embeddings (free tier: 10M tokens)
JINA_API_KEY=<your-jina-key>
JINA_API_URL=https://api.jina.ai/v1/embeddings
JINA_MODEL=jina-embeddings-v5-text-small

# Guardian API (free registration: https://bonobo.capi.gutools.co.uk/register/developer)
GUARDIAN_API_KEY=<your-guardian-key>

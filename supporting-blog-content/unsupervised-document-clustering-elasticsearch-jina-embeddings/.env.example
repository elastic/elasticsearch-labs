# Copy this file to `.env` and fill in the values before running the notebook.
# The notebook calls `load_dotenv(override=True)`, so local .env values take
# precedence over any inherited shell environment.

# --- Elasticsearch ---
# Provide either ELASTIC_CLOUD_ID (Elastic Cloud) or ELASTIC_HOST (self-managed
# or serverless URL). ELASTIC_API_KEY is always required.
ELASTIC_CLOUD_ID=
ELASTIC_HOST=
ELASTIC_API_KEY=
# Base index name used by the notebook. Daily indices are derived from it.
ELASTIC_INDEX_CLUSTERING=docs-clustering
ELASTIC_VERIFY_CERTS=true

# --- Jina embeddings ---
# Free tier at https://jina.ai/embeddings/ includes 10M tokens, enough to run
# the full notebook (~4.25M tokens for the clustering pass).
JINA_API_KEY=
JINA_API_URL=https://api.jina.ai/v1/embeddings
JINA_MODEL=jina-embeddings-v5-text-small
JINA_BATCH_SIZE=50

# --- Guardian Open Platform ---
# Free key at https://bonobo.capi.gutools.co.uk/register/developer
GUARDIAN_API_KEY=

# --- Dataset (BBC via HuggingFace) ---
HF_DATASET_NAME=RealTimeData/bbc_news_alltime
HF_DATASET_SPLIT=train
HF_SAMPLE_SIZE=10000

# --- Logging ---
LOG_LEVEL=INFO

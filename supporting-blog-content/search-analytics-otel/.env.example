# =============================================================================
# Search Analytics with OTel — Configuration
# =============================================================================
# Copy to .env and fill in your values:
#   cp .env.example .env

# --- Search Cluster (product data) ---
# Elastic Cloud console → your deployment → Elasticsearch endpoint
ELASTICSEARCH_URL=https://your-deployment.es.region.cloud.es.io
# Kibana → Stack Management → API Keys → Create (index + read privileges)
ELASTIC_API_KEY=<your Elasticsearch API key>
SEARCH_INDEX=products

# --- Observability (OTel traces via Managed OTLP) ---
# Elastic Cloud → your deployment → Managed OTLP → copy endpoint URL
OTEL_EXPORTER_OTLP_ENDPOINT=https://your-deployment.ingest.region.gcp.elastic-cloud.com:443

# Elastic shows:  Authorization=ApiKey <base64-key>
# You must use:   Authorization=ApiKey%20<base64-key>
#   ↑ replace the literal space with %20 (OpenTelemetry requires URL-encoded headers)
# Keep the quotes. Paste only the base64 key from Elastic (do not add another "ApiKey " prefix).
# The app refuses to start (with a reminder) if you leave the literal space in.
OTEL_EXPORTER_OTLP_HEADERS="Authorization=ApiKey%20your-base64-encoded-api-key"

# Required for Elastic managed OTLP (default gRPC will fail)
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Shown in Kibana APM / Blog 6 SLO setup (mapped to OTEL_RESOURCE_ATTRIBUTES by app.py)
OTEL_SERVICE_NAME=search-analytics-demo

# Sample all traces (recommended for demos)
OTEL_TRACES_SAMPLER=always_on

# --- Server ---
PORT=8000

# --- Optional: single deployment for search + traces (fine for demos) ---
# Point ELASTICSEARCH_URL and OTEL_EXPORTER_OTLP_ENDPOINT at the same Elastic Cloud
# deployment. For production, use separate clusters so observability load does not
# affect search performance.

# --- Alternative: EDOT Collector (self-managed) ---
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# See: https://www.elastic.co/docs/reference/edot-collector
